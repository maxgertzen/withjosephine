{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/data/*": ["../src/data/*"],
      "@/lib/emails/*": ["../src/lib/emails/*"],
      "@/lib/theme/*": ["../src/lib/theme/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
