{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["../src/*"],
      "react": ["../node_modules/@types/react"],
      "react/*": ["../node_modules/@types/react/*"],
      "react-dom": ["../node_modules/@types/react-dom"],
      "react-dom/*": ["../node_modules/@types/react-dom/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
