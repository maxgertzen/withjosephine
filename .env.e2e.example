# Playwright E2E environment template.
# Copy to .env.e2e and source before running `pnpm exec playwright test`.
# globalSetup asserts the env-guards in D-13.

# Stripe — TEST mode key only. globalSetup aborts if this doesn't start with "sk_test_".
STRIPE_SECRET_KEY=sk_test_dummy_for_e2e
STRIPE_WEBHOOK_SECRET=whsec_dummy_for_e2e

# Sanity write token — MUST be empty string in E2E. globalSetup aborts otherwise.
SANITY_WRITE_TOKEN=
SANITY_READ_TOKEN=dummy_read_token_for_e2e

# Sanity client env — required for Next dev boot. Project ID can be fake;
# SANITY_API_HOST (set at runtime by globalSetup) overrides the API host.
NEXT_PUBLIC_SANITY_PROJECT_ID=e8jsb14m
NEXT_PUBLIC_SANITY_DATASET=staging
NEXT_PUBLIC_SANITY_STUDIO_URL=http://localhost:3333

# R2 public host — `src/lib/constants.ts:38` throws at module-init if missing.
# Not a secret, just the brand's CDN hostname.
NEXT_PUBLIC_R2_PUBLIC_HOST=images.withjosephine.com

# Soft-launch / analytics flags — read at boot.
NEXT_PUBLIC_UNDER_CONSTRUCTION=false
NEXT_PUBLIC_TRACK_NON_PROD=false

# Turnstile bypass — uses Cloudflare's always-pass testing site key.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
NEXT_PUBLIC_BOOKING_TURNSTILE_BYPASS=1
BOOKING_TURNSTILE_BYPASS=1
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Listen token / HMAC secrets — dummy values for boot.
LISTEN_TOKEN_SECRET=e2e_listen_token_secret_dummy
ADMIN_API_KEY=e2e_admin_api_key_dummy

# Marker — Playwright config sets E2E=1 in webServer.env.
E2E=1
