exports[`email HTML byte-equality: emailDay7Delivery > renders the exact same HTML as the baseline snapshot 1`] = `"<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd"><html dir="ltr" lang="en"><head><meta content="text/html; charset=UTF-8" http-equiv="Content-Type"/><meta name="x-apple-disable-message-reformatting"/></head><body style="background-color:rgb(245,240,232);margin:0;padding:0"><!--$--><!--html--><!--head--><div style="display:none;overflow:hidden;line-height:1px;opacity:0;max-height:0;max-width:0" data-skip-in-text="true">A short note before you press play.<div> ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿</div></div><!--body--><table border="0" width="100%" cellPadding="0" cellSpacing="0" role="presentation" align="center"><tbody><tr><td style="background-color:rgb(245,240,232);margin:0;padding:0"><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="max-width:600px;background-color:rgb(250,248,244);border-style:solid;border-width:1px;border-color:rgb(232,213,196);border-radius:0.25rem;margin:0 auto"><tbody><tr style="width:100%"><td><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="text-align:center;padding:44px 48px 8px 48px"><tbody><tr><td><p style="font-family:&quot;Cormorant Garamond&quot;,Georgia,serif;color:rgb(28,25,53);margin:0;font-weight:500;font-size:38px;line-height:1;letter-spacing:0.005em">Josephine</p><p style="font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;color:rgb(122,111,106);text-transform:uppercase;margin:10px 0 0 0;font-size:11px;letter-spacing:0.32em">Soul Readings</p></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="text-align:center;padding:32px 48px 8px 48px"><tbody><tr><td><table role="presentation" cellPadding="0" cellSpacing="0" border="0" width="100%"><tbody><tr><td width="18%"><div style="border-top-style:solid;border-top-width:1px;border-color:rgb(196,164,107)"></div></td><td align="center" style="font-family:&quot;Cormorant Garamond&quot;,Georgia,serif;color:rgb(28,25,53);padding:0 16px;font-weight:500;font-size:28px;line-height:1.2;white-space:nowrap">Your reading is ready</td><td width="18%"><div style="border-top-style:solid;border-top-width:1px;border-color:rgb(196,164,107)"></div></td></tr></tbody></table></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;color:rgb(61,54,51);padding:32px 48px 16px 48px;line-height:1.75;font-size:16px"><tbody><tr><td><p style="font-size:16px;line-height:1.75;margin-top:16px;margin-bottom:16px">Hi Ada,</p><p style="font-size:16px;line-height:1.75;margin-top:16px;margin-bottom:16px">Your Soul Blueprint reading is here.</p><p style="font-size:16px;line-height:1.75;margin-top:16px;margin-bottom:16px">Open it whenever the timing feels right. It is saved to you, not to a deadline. Headphones if you have them, somewhere quiet if you can.</p></td></tr></tbody></table><div style="padding:8px 48px 8px 48px;text-align:center"><a href="https://withjosephine.com/listen/preview" style="line-height:100%;text-decoration:none;display:inline-block;max-width:100%;mso-padding-alt:0px;background-color:rgb(28,25,53);color:rgb(250,248,244);font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;text-decoration-line:none;padding:16px 32px;font-size:16px;border-radius:50px;letter-spacing:0.02em;padding-top:16px;padding-right:32px;padding-bottom:16px;padding-left:32px" target="_blank"><span><!--[if mso]><i style="mso-font-width:400%;mso-text-raise:24" hidden>&#8202;&#8202;&#8202;&#8202;</i><![endif]--></span><span style="max-width:100%;display:inline-block;line-height:120%;mso-padding-alt:0px;mso-text-raise:12px">Open your reading</span><span><!--[if mso]><i style="mso-font-width:400%" hidden>&#8202;&#8202;&#8202;&#8202;&#8203;</i><![endif]--></span></a></div><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;color:rgb(61,54,51);padding:24px 48px 16px 48px;line-height:1.75;font-size:16px"><tbody><tr><td><p style="font-size:16px;line-height:1.75;margin-top:16px;margin-bottom:16px">Tap below to open your reading. You will be signed in for the next seven days, so you can come back to the voice note and the PDF without asking again.</p><p style="font-size:16px;line-height:1.75;margin-top:16px;margin-bottom:16px">This link is just for you; please do not share it.</p><p style="font-size:16px;line-height:1.75;margin-top:16px;margin-bottom:16px">Your reading stays here for the next ninety days. If a link expires sooner, just email me and I will send you a fresh one.</p><p style="font-size:16px;line-height:1.75;margin-top:16px;margin-bottom:16px">If anything you hear sits hard, or a question opens up after, write to me. I would rather know than not.</p></td></tr></tbody></table><div style="padding:0 48px"><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="background-color:rgb(245,240,232);border-radius:0.25rem;padding:20px 24px"><tbody><tr><td><p style="font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;color:rgb(122,111,106);text-transform:uppercase;margin:0 0 4px 0;font-size:11px;letter-spacing:0.18em">Your reading</p><p style="font-family:&quot;Cormorant Garamond&quot;,Georgia,serif;color:rgb(28,25,53);margin:0 0 12px 0;font-size:22px">Soul Blueprint</p><p style="font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;color:rgb(122,111,106);margin:0;font-size:14px">Voice note + PDF</p></td></tr></tbody></table></div><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="font-family:&quot;Cormorant Garamond&quot;,Georgia,serif;font-style:italic;color:rgb(28,25,53);padding:36px 48px 16px 48px;font-size:22px;line-height:1.4"><tbody><tr><td><p style="margin:0 0 4px 0">With love,</p><p style="margin:0">Josephine ✦</p></td></tr></tbody></table><hr style="width:100%;border:none;border-top:1px solid #eaeaea;border-color:rgb(232,213,196);margin:0"/><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;color:rgb(122,111,106);padding:24px 48px 36px 48px;font-size:12px;line-height:1.7"><tbody><tr><td><p style="margin:0"><a href="mailto:hello@withjosephine.com" style="color:rgb(28,25,53);text-decoration-line:none" target="_blank">hello@withjosephine.com</a> · <a href="https://withjosephine.com" style="color:rgb(28,25,53);text-decoration-line:none" target="_blank">withjosephine.com</a></p><p style="margin:8px 0 0 0">Readings are offered for entertainment and personal reflection.</p></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table><!--/$--></body></html>"`;

