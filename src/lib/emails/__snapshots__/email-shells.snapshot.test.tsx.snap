106);text-transform:uppercase;margin:10px 0 0 0;font-size:11px;letter-spacing:0.32em">Soul Readings</p></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="text-align:center;padding:32px 48px 8px 48px"><tbody><tr><td><table role="presentation" cellPadding="0" cellSpacing="0" border="0" width="100%"><tbody><tr><td width="18%"><div style="border-top-style:solid;border-top-width:1px;border-color:rgb(196,164,107)"></div></td><td align="center" style="font-family:&quot;Cormorant Garamond&quot;,Georgia,serif;color:rgb(28,25,53);padding:0 16px;font-weight:500;font-size:28px;line-height:1.2">A reading, for you</td><td width="18%"><div style="border-top-style:solid;border-top-width:1px;border-color:rgb(196,164,107)"></div></td></tr></tbody></table></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;color:rgb(61,54,51);padding:32px 48px 16px 48px;line-height:1.75;font-size:16px"><tbody><tr><td><p style="font-size:16px;line-height:1.75;margin-top:16px;margin-bottom:16px">Hi River,</p><p style="font-size:16px;line-height:1.75;margin-top:16px;margin-bottom:16px">Maya has given you a Soul Blueprint with me. When youвАЩre ready, tap the link below to begin. A short welcome opens first, then a form so I know what to read for you: your birth details, what youвАЩre sitting with, anything youвАЩd like me to keep in mind. After that, the reading lands in your inbox within seven days.</p></td></tr></tbody></table><div style="padding:0 48px 16px 48px"><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="background-color:rgb(245,240,232);border-radius:0.25rem;padding:20px 24px"><tbody><tr><td><p style="font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;color:rgb(122,111,106);text-transform:uppercase;margin:0 0 6px 0;font-size:11px;letter-spacing:0.18em">A note from Maya</p><p style="font-family:&quot;Cormorant Garamond&quot;,Georgia,serif;font-style:italic;color:rgb(28,25,53);margin:0;font-size:18px;line-height:1.5">Thinking of you вАФ I hope this lands at the right moment.</p></td></tr></tbody></table></div><div style="padding:8px 48px 8px 48px;text-align:center"><a href="https://withjosephine.com/gift/claim/preview" style="line-height:100%;text-decoration:none;display:inline-block;max-width:100%;mso-padding-alt:0px;background-color:rgb(28,25,53);color:rgb(250,248,244);font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;text-decoration-line:none;border-radius:0.25rem;padding:14px 28px;font-size:15px;letter-spacing:0.08em;padding-top:14px;padding-right:28px;padding-bottom:14px;padding-left:28px" target="_blank"><span><!--[if mso]><i style="mso-font-width:466.6666666666667%;mso-text-raise:21" hidden>&#8202;&#8202;&#8202;</i><![endif]--></span><span style="max-width:100%;display:inline-block;line-height:120%;mso-padding-alt:0px;mso-text-raise:10.5px">Open your gift</span><span><!--[if mso]><i style="mso-font-width:466.6666666666667%" hidden>&#8202;&#8202;&#8202;&#8203;</i><![endif]--></span></a><p style="font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;color:rgb(122,111,106);margin:16px 0 0 0;font-size:13px;line-height:1.6">This link is for you. Open it from a quiet moment; a short welcome and then a ten-minute form follow.</p></div><div style="padding:20px 48px 0 48px"><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="background-color:rgb(245,240,232);border-radius:0.25rem;padding:20px 24px"><tbody><tr><td><p style="font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;color:rgb(122,111,106);text-transform:uppercase;margin:0 0 4px 0;font-size:11px;letter-spacing:0.18em">The gift</p><p style="font-family:&quot;Cormorant Garamond&quot;,Georgia,serif;color:rgb(28,25,53);margin:0 0 12px 0;font-size:22px">Soul Blueprint</p><p style="font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;color:rgb(122,111,106);margin:0;font-size:14px">Delivered within 7 days of your intake</p></td></tr></tbody></table></div><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="font-family:&quot;Cormorant Garamond&quot;,Georgia,serif;font-style:italic;color:rgb(28,25,53);padding:36px 48px 16px 48px;font-size:22px;line-height:1.4"><tbody><tr><td><p style="margin:0 0 4px 0">With love,</p><p style="margin:0">Josephine вЬ¶</p></td></tr></tbody></table><hr style="width:100%;border:none;border-top:1px solid #eaeaea;border-color:rgb(232,213,196);margin:0"/><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;color:rgb(122,111,106);padding:24px 48px 36px 48px;font-size:12px;line-height:1.7"><tbody><tr><td><p style="margin:0"><a href="mailto:hello@withjosephine.com" style="color:rgb(28,25,53);text-decoration-line:none" target="_blank">hello@withjosephine.com</a>¬†¬Ј¬†<a href="https://withjosephine.com" style="color:rgb(28,25,53);text-decoration-line:none" target="_blank">withjosephine.com</a></p><p style="margin:8px 0 0 0">Readings are offered for entertainment and personal reflection.</p></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table><!--/$--></body></html>"`;

