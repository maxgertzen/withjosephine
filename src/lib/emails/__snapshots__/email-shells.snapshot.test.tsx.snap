ing happens until someone clicks.</p></td></tr></tbody></table><div style="padding:8px 48px 8px 48px;text-align:center"><a href="https://withjosephine.com/api/auth/magic-link/verify?token=preview" style="line-height:100%;text-decoration:none;display:inline-block;max-width:100%;mso-padding-alt:0px;background-color:rgb(28,25,53);color:rgb(250,248,244);font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;text-decoration-line:none;padding:16px 32px;font-size:16px;border-radius:50px;letter-spacing:0.02em;padding-top:16px;padding-right:32px;padding-bottom:16px;padding-left:32px" target="_blank"><span><!--[if mso]><i style="mso-font-width:400%;mso-text-raise:24" hidden>&#8202;&#8202;&#8202;&#8202;</i><![endif]--></span><span style="max-width:100%;display:inline-block;line-height:120%;mso-padding-alt:0px;mso-text-raise:12px">Open your reading</span><span><!--[if mso]><i style="mso-font-width:400%" hidden>&#8202;&#8202;&#8202;&#8202;&#8203;</i><![endif]--></span></a></div><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;color:rgb(122,111,106);text-align:center;padding:16px 48px 0 48px;font-size:13px;line-height:1.6"><tbody><tr><td><p style="margin:0">Or copy this link:<!-- --> <a href="https://withjosephine.com/api/auth/magic-link/verify?token=preview" style="color:rgb(28,25,53);text-decoration-line:none" target="_blank">https://withjosephine.com/api/auth/magic-link/verify?token=preview</a></p></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="font-family:&quot;Cormorant Garamond&quot;,Georgia,serif;font-style:italic;color:rgb(28,25,53);padding:36px 48px 16px 48px;font-size:22px;line-height:1.4"><tbody><tr><td><p style="margin:0 0 4px 0">With love,</p><p style="margin:0">Josephine ✦</p></td></tr></tbody></table><hr style="width:100%;border:none;border-top:1px solid #eaeaea;border-color:rgb(232,213,196);margin:0"/><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;color:rgb(122,111,106);padding:24px 48px 36px 48px;font-size:12px;line-height:1.7"><tbody><tr><td><p style="margin:0"><a href="mailto:hello@withjosephine.com" style="color:rgb(28,25,53);text-decoration-line:none" target="_blank">hello@withjosephine.com</a> · <a href="https://withjosephine.com" style="color:rgb(28,25,53);text-decoration-line:none" target="_blank">withjosephine.com</a></p><p style="margin:8px 0 0 0">Readings are offered for entertainment and personal reflection.</p></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table><!--/$--></body></html>"`;

exports[`email HTML byte-equality: emailOrderConfirmation > renders the exact same HTML as the baseline snapshot 1`] = `"<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd"><html dir="ltr" lang="en"><head><meta content="text/html; charset=UTF-8" http-equiv="Content-Type"/><meta name="x-apple-disable-message-reformatting"/></head><body style="background-color:rgb(245,240,232);margin:0;padding:0"><!--$--><!--html--><!--head--><div style="display:none;overflow:hidden;line-height:1px;opacity:0;max-height:0;max-width:0" data-skip-in-text="true">Your reading is booked: what happens next<div> ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿</div></div><!--body--><table border="0" width="100%" cellPadding="0" cellSpacing="0" role="presentation" align="center"><tbody><tr><td style="background-color:rgb(245,240,232);margin:0;padding:0"><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="max-width:600px;background-color:rgb(250,248,244);border-style:solid;border-width:1px;border-color:rgb(232,213,196);border-radius:0.25rem;margin:0 auto"><tbody><tr style="width:100%"><td><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="text-align:center;padding:44px 48px 8px 48px"><tbody><tr><td><p style="font-family:&quot;Cormorant Garamond&quot;,Georgia,serif;color:rgb(28,25,53);margin:0;font-weight:500;font-size:38px;line-height:1;letter-spacing:0.005em">Josephine</p><p style="font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;color:rgb(122,111,106);text-transform:uppercase;margin:10px 0 0 0;font-size:11px;letter-spacing:0.32em">Soul Readings</p></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="text-align:center;padding:32px 48px 8px 48px"><tbody><tr><td><table role="presentation" cellPadding="0" cellSpacing="0" border="0" width="100%"><tbody><tr><td width="18%"><div style="border-top-style:solid;border-top-width:1px;border-color:rgb(196,164,107)"></div></td><td align="center" style="font-family:&quot;Cormorant Garamond&quot;,Georgia,serif;color:rgb(28,25,53);padding:0 16px;font-weight:500;font-size:28px;line-height:1.2;white-space:nowrap">Your reading is booked</td><td width="18%"><div style="border-top-style:solid;border-top-width:1px;border-color:rgb(196,164,107)"></div></td></tr></tbody></table></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;color:rgb(61,54,51);padding:32px 48px 16px 48px;line-height:1.75;font-size:16px"><tbody><tr><td><p style="font-size:16px;line-height:1.75;margin-top:16px;margin-bottom:16px">Hi Ada,</p><p style="font-size:16px;line-height:1.75;margin-top:16px;margin-bottom:16px">Thank you for booking a Soul Blueprint reading with me. I have your intake and your payment, and you don’t need to do anything else.</p><p style="font-size:16px;line-height:1.75;margin-top:16px;margin-bottom:16px">I’ll begin your reading in the next day or two. You’ll hear a short note from me when I do, just so you know it’s underway. Your voice note and PDF will arrive within seven days, to this email address.</p><p style="font-size:16px;line-height:1.75;margin-top:16px;margin-bottom:16px">If anything comes up before then. A question, a detail you forgot to mention, anything at all. Just reply to this email; it comes straight to me.</p></td></tr></tbody></table><div style="padding:0 48px"><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="background-color:rgb(245,240,232);border-radius:0.25rem;padding:20px 24px"><tbody><tr><td><p style="font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;color:rgb(122,111,106);text-transform:uppercase;margin:0 0 4px 0;font-size:11px;letter-spacing:0.18em">Your reading</p><p style="font-family:&quot;Cormorant Garamond&quot;,Georgia,serif;color:rgb(28,25,53);margin:0 0 12px 0;font-size:22px">Soul Blueprint</p><p style="font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;color:rgb(61,54,51);margin:0;font-size:14px"><span style="color:rgb(122,111,106)">Delivery within 7 days</span> · <span>$179</span></p></td></tr></tbody></table></div><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="font-family:&quot;Cormorant Garamond&quot;,Georgia,serif;font-style:italic;color:rgb(28,25,53);padding:36px 48px 16px 48px;font-size:22px;line-height:1.4"><tbody><tr><td><p style="margin:0 0 4px 0">With love,</p><p style="margin:0">Josephine ✦</p></td></tr></tbody></table><hr style="width:100%;border:none;border-top:1px solid #eaeaea;border-color:rgb(232,213,196);margin:0"/><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;color:rgb(122,111,106);padding:24px 48px 36px 48px;font-size:12px;line-height:1.7"><tbody><tr><td><p style="margin:0"><a href="mailto:hello@withjosephine.com" style="color:rgb(28,25,53);text-decoration-line:none" target="_blank">hello@withjosephine.com</a> · <a href="https://withjosephine.com" style="color:rgb(28,25,53);text-decoration-line:none" target="_blank">withjosephine.com</a></p><p style="margin:8px 0 0 0">Readings are offered for entertainment and personal reflection.</p></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;color:rgb(122,111,106);padding:0 48px 32px 48px;font-size:12px;line-height:1.7"><tbody><tr><td><p style="margin:0">Need a copy of your data?<!-- --> <a href="https://withjosephine.com/privacy/export?t=preview" style="color:rgb(28,25,53);text-decoration-line:none" target="_blank">Request an export<!-- --> →</a></p></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table><!--/$--></body></html>"`;

exports[`email HTML byte-equality: emailPrivacyExport > renders the exact same HTML as the baseline snapshot 1`] = `"<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd"><html dir="ltr" lang="en"><head><meta content="text/html; charset=UTF-8" http-equiv="Content-Type"/><meta name="x-apple-disable-message-reformatting"/></head><body style="background-color:rgb(245,240,232);margin:0;padding:0"><!--$--><!--html--><!--head--><div style="display:none;overflow:hidden;line-height:1px;opacity:0;max-height:0;max-width:0" data-skip-in-text="true">Your Josephine data export is ready<div> ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿ ‌​‍‎‏﻿</div></div><!--body--><table border="0" width="100%" cellPadding="0" cellSpacing="0" role="presentation" align="center"><tbody><tr><td style="background-color:rgb(245,240,232);margin:0;padding:0"><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="max-width:600px;background-color:rgb(250,248,244);border-style:solid;border-width:1px;border-color:rgb(232,213,196);border-radius:0.25rem;margin:0 auto"><tbody><tr style="width:100%"><td><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="text-align:center;padding:44px 48px 8px 48px"><tbody><tr><td><p style="font-family:&quot;Cormorant Garamond&quot;,Georgia,serif;color:rgb(28,25,53);margin:0;font-weight:500;font-size:38px;line-height:1;letter-spacing:0.005em">Josephine</p><p style="font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;color:rgb(122,111,106);text-transform:uppercase;margin:10px 0 0 0;font-size:11px;letter-spacing:0.32em">Soul Readings</p></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="text-align:center;padding:32px 48px 8px 48px"><tbody><tr><td><table role="presentation" cellPadding="0" cellSpacing="0" border="0" width="100%"><tbody><tr><td width="18%"><div style="border-top-style:solid;border-top-width:1px;border-color:rgb(196,164,107)"></div></td><td align="center" style="font-family:&quot;Cormorant Garamond&quot;,Georgia,serif;color:rgb(28,25,53);padding:0 16px;font-weight:500;font-size:28px;line-height:1.2">Your data export is ready</td><td width="18%"><div style="border-top-style:solid;border-top-width:1px;border-color:rgb(196,164,107)"></div></td></tr></tbody></table></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;color:rgb(61,54,51);padding:32px 48px 16px 48px;line-height:1.75;font-size:16px"><tbody><tr><td><p style="font-size:16px;line-height:1.75;margin-top:16px;margin-bottom:16px">Hi,</p><p style="font-size:16px;line-height:1.75;margin-top:16px;margin-bottom:16px">Your Josephine data export is ready.</p><p style="font-size:16px;line-height:1.75;margin-top:16px;margin-bottom:16px">It contains the data we hold for your reading: intake answers, consent records, transactional records, photos, voice notes, and PDFs (where delivered).</p></td></tr></tbody></table><div style="padding:8px 48px 8px 48px;text-align:center"><a href="https://images.withjosephine.com/exports/preview.zip" style="line-height:100%;text-decoration:none;display:inline-block;max-width:100%;mso-padding-alt:0px;background-color:rgb(28,25,53);color:rgb(250,248,244);font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;text-decoration-line:none;padding:16px 32px;font-size:16px;border-radius:50px;letter-spacing:0.02em;padding-top:16px;padding-right:32px;padding-bottom:16px;padding-left:32px" target="_blank"><span><!--[if mso]><i style="mso-font-width:400%;mso-text-raise:24" hidden>&#8202;&#8202;&#8202;&#8202;</i><![endif]--></span><span style="max-width:100%;display:inline-block;line-height:120%;mso-padding-alt:0px;mso-text-raise:12px">Download your export (ZIP)</span><span><!--[if mso]><i style="mso-font-width:400%" hidden>&#8202;&#8202;&#8202;&#8202;&#8203;</i><![endif]--></span></a></div><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;color:rgb(61,54,51);padding:24px 48px 16px 48px;line-height:1.75;font-size:16px"><tbody><tr><td><p style="font-size:16px;line-height:1.75;margin-top:16px;margin-bottom:16px">This link expires in 7 days. If you have any questions, reply to this email or write to hello@withjosephine.com.</p></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="font-family:&quot;Cormorant Garamond&quot;,Georgia,serif;font-style:italic;color:rgb(28,25,53);padding:20px 48px 16px 48px;font-size:22px;line-height:1.4"><tbody><tr><td><p style="margin:0 0 4px 0">With love,</p><p style="margin:0">Josephine ✦</p></td></tr></tbody></table><hr style="width:100%;border:none;border-top:1px solid #eaeaea;border-color:rgb(232,213,196);margin:0"/><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="font-family:Inter,-apple-system,Helvetica,Arial,sans-serif;color:rgb(122,111,106);padding:24px 48px 36px 48px;font-size:12px;line-height:1.7"><tbody><tr><td><p style="margin:0"><a href="mailto:hello@withjosephine.com" style="color:rgb(28,25,53);text-decoration-line:none" target="_blank">hello@withjosephine.com</a> · <a href="https://withjosephine.com" style="color:rgb(28,25,53);text-decoration-line:none" target="_blank">withjosephine.com</a></p><p style="margin:8px 0 0 0">Readings are offered for entertainment and personal reflection.</p></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table><!--/$--></body></html>"`;
