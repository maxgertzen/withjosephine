# Sanity — shared between www/ and studio/
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity write token — for seed script only (never expose to client)
SANITY_WRITE_TOKEN=your-write-token

# Studio uses these (prefixed for Sanity CLI)
SANITY_STUDIO_PROJECT_ID=your-project-id
SANITY_STUDIO_DATASET=production

# Web3Forms — contact form submissions (public key, safe for client-side)
# Get your access key at https://web3forms.com (enter josephine@domain.com)
NEXT_PUBLIC_WEB3FORMS_KEY=your-web3forms-access-key
