# Sanity — shared between www/ and studio/
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production

# Public URL of the deployed Sanity Studio. Click-to-edit overlays from
# <VisualEditing /> link back to this origin. Use the local dev URL during
# `pnpm studio:dev` (http://localhost:3333) and the hosted URL elsewhere.
NEXT_PUBLIC_SANITY_STUDIO_URL=https://your-project.sanity.studio

# Sanity Viewer (read) token — used server-side to subscribe to live content
# changes and to authenticate the draft-mode handler with Sanity's API.
SANITY_READ_TOKEN=your-read-token

# Sanity write token — used by /api/booking and seed/migrate scripts.
# Editor permission. Never expose to the client.
SANITY_WRITE_TOKEN=your-write-token
SANITY_API_TOKEN=your-api-token

# Studio uses these (prefixed for Sanity CLI)
SANITY_STUDIO_PROJECT_ID=your-project-id
SANITY_STUDIO_DATASET=production

# Stripe — webhooks + reconcile cron only (Payment Links handle checkout itself)
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-signing-secret

# Resend — transactional email (booking confirmation, day-2/7 emails, contact form)
RESEND_API_KEY=re_your-key
NOTIFICATION_EMAIL=hello@withjosephine.com

# Cloudflare Turnstile — spam protection on booking + contact forms
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA-your-site-key
TURNSTILE_SECRET_KEY=0x4AAAAAAA-your-secret-key

# Dev-only: bypass Turnstile verification (server-side helper checks both vars).
# NEXT_PUBLIC_BOOKING_TURNSTILE_BYPASS=1
# BOOKING_TURNSTILE_BYPASS=1

# Cloudflare R2 — booking photo uploads (custom domain images.withjosephine.com)
R2_ACCOUNT_ID=your-cf-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret
R2_BUCKET_NAME=withjosephine-booking-photos

# Bearer token for ad-hoc /api/cron/* invocation (CF cron triggers bypass).
CRON_SECRET=openssl-rand-hex-32

# HMAC secret signing /listen/[token] URLs in the Day +7 delivery email.
LISTEN_TOKEN_SECRET=openssl-rand-hex-32

# Submission persistence (ADR-001)
# Driver: "sqlite" for local dev/tests (default); "d1" for the deployed Worker.
# In production the Worker reaches D1 via the `withjosephine_bookings` binding
# declared in wrangler.jsonc — no credentials needed.
# BOOKING_DB_DRIVER=sqlite
# Local SQLite path. ":memory:" works for ephemeral runs; default file is .local/booking.db
# BOOKING_DB_PATH=.local/booking.db

# Feature flags
# Set to "1" or "true" to show under-construction page instead of the full site
# NEXT_PUBLIC_UNDER_CONSTRUCTION=1

# Cloudflare Web Analytics — set token to enable (cookieless, no consent needed)
# Get from CF dashboard → your site → Web Analytics → Copy token
# NEXT_PUBLIC_CF_ANALYTICS_TOKEN=your-cf-analytics-token

# Mixpanel — funnel analytics (SPEC §15). Project token is public-by-design;
# ships in the browser bundle. Get from mixpanel.com → Project Settings.
# Geo-conditional consent banner gates SDK init for EU/EEA/UK/CH/CA visitors;
# the rest of the world inits unconditionally. Leave empty to no-op the SDK.
# NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-project-token

# Mixpanel non-prod opt-in. Tracking is OFF by default in local / preview /
# workers-dev environments to avoid polluting the production project. Set
# this to "1" only when you specifically want to verify new event wiring
# from a non-prod host (e.g. testing a freshly-added event before merge).
# Production (withjosephine.com / www.withjosephine.com) is always tracked
# regardless of this flag — subject to the consent banner gate.
# NEXT_PUBLIC_TRACK_NON_PROD=1
