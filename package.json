{
  "name": "josephine-soul-readings",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "generate-tokens": "tsx scripts/generate-tokens.ts",
    "generate-fonts": "tsx scripts/generate-fonts.ts",
    "sync-readings-from-sanity": "tsx scripts/sync-readings-from-sanity.ts",
    "prebuild": "pnpm generate-tokens && pnpm generate-fonts && pnpm sync-readings-from-sanity",
    "build": "next build",
    "analyze": "ANALYZE=true next build",
    "cf:build": "pnpm build && opennextjs-cloudflare build && pnpm cf:strip-og && pnpm sentry:sourcemaps",
    "cf:strip-og": "node scripts/strip-vercel-og.mjs",
    "sentry:sourcemaps": "node scripts/upload-sourcemaps.mjs",
    "email:preview": "tsx scripts/render-email-previews.ts",
    "cf:dev": "wrangler dev --port 8788",
    "start": "next start",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.scripts.json",
    "typecheck:scripts": "tsc --noEmit -p tsconfig.scripts.json",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest",
    "studio:dev": "pnpm --dir studio run dev",
    "studio:build": "pnpm --dir studio run build",
    "studio:deploy": "pnpm --dir studio run deploy",
    "optimize-images": "tsx scripts/optimize-images.ts",
    "build-cities": "tsx scripts/build-cities-json.ts",
    "migrate:create": "wrangler d1 migrations create withjosephine_bookings",
    "migrate:list:prod": "wrangler d1 migrations list withjosephine_bookings --remote",
    "migrate:list:staging": "wrangler d1 migrations list withjosephine_bookings --env staging --remote",
    "migrate:list:local": "wrangler d1 migrations list withjosephine_bookings --local",
    "migrate:apply:prod": "wrangler d1 migrations apply withjosephine_bookings --remote",
    "migrate:apply:staging": "wrangler d1 migrations apply withjosephine_bookings --env staging --remote",
    "migrate:apply:local": "wrangler d1 migrations apply withjosephine_bookings --local",
    "seed:staging": "tsx scripts/seed-staging-dataset.ts"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.5.2",
    "@portabletext/react": "^6.2.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@sanity/asset-utils": "^2.3.0",
    "@sanity/client": "^7.22.0",
    "@sanity/visual-editing": "5.3.4",
    "@sanity/webhook": "^4.0.4",
    "@sentry/browser": "^10.52.0",
    "@sentry/cloudflare": "^10.52.0",
    "aws4fetch": "^1.0.20",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "escape-html": "^1.0.3",
    "fflate": "^0.8.2",
    "fuse.js": "^7.3.0",
    "lucide-react": "^1.14.0",
    "mixpanel-browser": "^2.78.0",
    "motion": "^12.38.0",
    "next": "16.2.6",
    "next-sanity": "^12.4.5",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "resend": "^6.12.3",
    "server-only": "^0.0.1",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "overrides": {
      "js-yaml@<3.14.2": "^3.14.2",
      "fast-xml-parser@<5.7.0": "^5.7.0",
      "postcss@<8.5.10": "^8.5.10",
      "uuid@<14.0.0": "^14.0.0",
      "@babel/plugin-transform-modules-systemjs@<7.29.4": "^7.29.4",
      "fast-uri@<3.1.2": "^3.1.2",
      "fast-xml-builder@<1.1.7": "^1.1.7"
    },
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "@tailwindcss/oxide",
      "better-sqlite3",
      "core-js-pure",
      "esbuild",
      "sharp",
      "unrs-resolver",
      "workerd"
    ]
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@hono/node-server": "^2.0.2",
    "@next/bundle-analyzer": "^16.2.6",
    "@opennextjs/cloudflare": "1.19.4",
    "@playwright/test": "^1.60.0",
    "@sentry/cli": "^3.4.1",
    "@storybook/nextjs": "^10.3.6",
    "@storybook/react": "^10.3.6",
    "@tailwindcss/postcss": "4.1.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/escape-html": "^1.0.4",
    "@types/mixpanel-browser": "^2.66.0",
    "@types/node": "^22.19.18",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "better-sqlite3": "^12.9.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "happy-dom": "^20.9.0",
    "hono": "^4.12.18",
    "msw": "^2.14.6",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "storybook": "^10.3.6",
    "tailwindcss": "4.1.12",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.90.0"
  }
}
